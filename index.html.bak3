<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hitta i Butiken</title>
  <style>
    :root {
      --header-height: 96px;
      --search-height: 52px;
      --surface: #ffffff;
      --surface-soft: #f8faf8;
      --text: #1f2937;
      --muted: #6b7280;
      --accent: #2f855a;
      --accent-soft: #e6f4ec;
      --border: #e5e7eb;
      --shadow-soft: 0 6px 18px rgba(17, 24, 39, 0.08);
      --shadow-panel: 0 -10px 28px rgba(17, 24, 39, 0.14);
      --radius-lg: 18px;
      --radius-pill: 999px;
      --transition: 220ms ease;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      height: 100%;
      font-family: "Segoe UI", "Helvetica Neue", sans-serif;
      color: var(--text);
      background: linear-gradient(180deg, #f7faf7 0%, #eef5ef 100%);
      overflow: hidden;
    }

    .app {
      position: relative;
      height: 100dvh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
      padding-bottom: 120px;
      width: 100%;
    }

    .header {
      position: relative;
      height: var(--header-height);
      background: #d90416;
      box-shadow: 0 6px 18px rgba(217, 4, 22, 0.28);
      z-index: 50;
      display: grid;
      place-items: center;
    }

    .header-main {
      height: 100%;
      display: grid;
      place-items: center;
      padding: 0 14px;
      width: 100%;
    }

    .logo {
      display: block;
      text-align: center;
    }

    .logo-text {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: 0.3px;
      white-space: nowrap;
      color: #ffffff;
    }

    .logo-subtitle {
      margin-top: 4px;
      font-size: 0.8rem;
      font-weight: 500;
      color: #ffffff;
      opacity: 0.95;
      white-space: nowrap;
    }

    .logo-black,
    .logo-red {
      color: #ffffff;
    }

    .icon-button {
      border: none;
      background: var(--surface-soft);
      width: 34px;
      height: 34px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      color: #374151;
      box-shadow: inset 0 0 0 1px #e9ecef;
      cursor: pointer;
    }

    .content {
      padding: 14px 12px 0;
    }

    .search-wrap {
      padding: 6px 0 20px;
      background: transparent;
      position: relative;
      z-index: 25;
    }

    .search {
      width: 100%;
      height: var(--search-height);
      border-radius: var(--radius-pill);
      border: 1px solid var(--border);
      background: var(--surface);
      box-shadow: var(--shadow-soft);
      display: flex;
      align-items: center;
      padding: 0 14px;
      gap: 10px;
    }

    .search input {
      border: none;
      width: 100%;
      outline: none;
      font-size: 0.96rem;
      color: var(--text);
      background: transparent;
    }

    .search input::placeholder {
      color: #9ca3af;
    }

    .search-result {
      position: relative;
      width: 100%;
      border: none;
      background: transparent;
      text-align: left;
      padding: 14px 14px;
      border-bottom: 1px solid #f1f5f9;
      cursor: pointer;
      transition: background-color 160ms ease, color 160ms ease, padding-left 160ms ease;
    }

    .search-result::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 0;
      background: #d90416;
      transition: width 160ms ease;
    }

    .search-result:hover,
    .search-result:focus-visible {
      background: #fdecee;
      padding-left: 18px;
      outline: none;
    }

    .search-result:hover::before,
    .search-result:focus-visible::before {
      width: 5px;
    }

    .search-result:last-child {
      border-bottom: none;
    }

    .search-result-name {
      font-size: 1.02rem;
      font-weight: 600;
      color: #1f2937;
    }

    .search-result-meta {
      margin-top: 4px;
      font-size: 0.92rem;
      color: #6b7280;
    }

    .search-result-category {
      color: #d90416;
      font-weight: 700;
    }

    .search-side-panel {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(92vw, 500px);
      background: #ffffff;
      border-left: 1px solid #e5e7eb;
      box-shadow: -14px 0 28px rgba(17, 24, 39, 0.16);
      transform: translateX(103%);
      transition: transform 240ms ease;
      z-index: 55;
      display: flex;
      flex-direction: column;
    }

    .search-side-panel.open {
      transform: translateX(0);
    }

    .search-side-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 12px 10px;
      border-bottom: 1px solid #edf2f7;
    }

    .search-side-title {
      font-size: 1.14rem;
      font-weight: 700;
      color: #111827;
    }

    .search-side-meta {
      font-size: 0.95rem;
      color: #6b7280;
      padding: 8px 12px;
      border-bottom: 1px solid #edf2f7;
    }

    .search-side-list {
      list-style: none;
      overflow-y: auto;
      flex: 1;
    }

    .load-more {
      margin: 10px 12px 12px;
      border: 1px solid #cbd5e1;
      background: #ffffff;
      color: #111827;
      border-radius: 999px;
      padding: 12px 16px;
      font-size: 0.98rem;
      font-weight: 600;
      cursor: pointer;
    }

    .load-more[hidden] {
      display: none;
    }

    .categories {
      position: sticky;
      top: 0;
      z-index: 30;
      padding: 0 0 12px;
      background: linear-gradient(180deg, #f7faf7 0%, rgba(247, 250, 247, 0.88) 65%, rgba(247, 250, 247, 0) 100%);
    }

    .category-scroll {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: thin;
      scrollbar-color: #cbd5e1 #f1f5f9;
      -ms-overflow-style: auto;
      padding-top: 4px;
      padding-bottom: 6px;
      -webkit-overflow-scrolling: touch;
    }

    .category-scroll::-webkit-scrollbar {
      height: 8px;
    }

    .category-scroll::-webkit-scrollbar-track {
      background: #f1f5f9;
      border-radius: 999px;
    }

    .category-scroll::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 999px;
    }

    .category {
      border: 1px solid var(--border);
      background: var(--surface);
      border-radius: var(--radius-pill);
      padding: 8px 14px;
      white-space: nowrap;
      font-size: 0.86rem;
      color: #374151;
      cursor: pointer;
      transition: background-color var(--transition), color var(--transition), border-color var(--transition), transform var(--transition);
      box-shadow: 0 2px 8px rgba(17, 24, 39, 0.05);
    }

    .category.active {
      background: #d90416;
      color: #ffffff;
      border-color: #d90416;
      font-weight: 600;
      box-shadow: 0 0 0 2px rgba(217, 4, 22, 0.2);
    }

    .map-section {
      margin-top: 6px;
      border-radius: 20px;
      overflow: hidden;
      background: #eef2f7;
      min-height: calc(100dvh - 270px);
      box-shadow: var(--shadow-soft);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px;
    }

    .map-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 10;
      border-radius: 14px;
      overflow: hidden;
      background: #ffffff;
    }

    .svg-container {
      width: 100%;
      height: 100%;
      background: #ffffff;
    }

    .svg-container > svg {
      width: 100%;
      height: 100%;
      display: block;
      touch-action: none;
      user-select: none;
      -webkit-user-select: none;
      background: #ffffff;
      shape-rendering: geometricPrecision;
      text-rendering: geometricPrecision;
    }

    .svg-container [id] {
      cursor: pointer;
    }

    .svg-container .shelf-selected,
    .svg-container .shelf-selected * {
      fill: #22c55e !important;
      stroke: #166534 !important;
      transition: fill 220ms ease, stroke 220ms ease, filter 220ms ease;
      filter: drop-shadow(0 0 8px rgba(34, 197, 94, 0.65));
    }

    .svg-container .shelf-selected text {
      fill: #064e3b !important;
      stroke: none !important;
    }

    .map-fallback {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px;
      text-align: center;
      background: rgba(255, 255, 255, 0.92);
      z-index: 4;
    }

    .map-fallback.hidden {
      display: none;
    }

    .map-help {
      font-size: 0.9rem;
      color: #4b5563;
      max-width: 280px;
    }

    .map-controls {
      position: absolute;
      top: 10px;
      right: 10px;
      z-index: 5;
      display: flex;
      gap: 8px;
    }

    .map-reset-btn {
      border: 1px solid #cbd5e1;
      background: #ffffff;
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 0.86rem;
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(17, 24, 39, 0.08);
    }

    .marker {
      position: absolute;
      transform: translate(-50%, -100%);
      border: none;
      width: 24px;
      height: 24px;
      border-radius: 50% 50% 50% 0;
      transform-origin: center;
      rotate: -45deg;
      background: #ef4444;
      box-shadow: 0 8px 20px rgba(239, 68, 68, 0.35);
      cursor: pointer;
      transition: transform var(--transition);
      z-index: 5;
    }

    .marker::after {
      content: "";
      position: absolute;
      inset: 6px;
      border-radius: 50%;
      background: #fff;
    }

    .marker:active {
      transform: translate(-50%, -100%) scale(0.95);
    }

    .product-panel {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--surface);
      border-radius: 20px 20px 0 0;
      box-shadow: var(--shadow-panel);
      z-index: 60;
      transform: translateY(100%);
      transition: transform 280ms ease;
      padding: 14px 16px 24px;
    }

    .product-panel.open {
      transform: translateY(0);
    }

    .drag-handle {
      width: 38px;
      height: 4px;
      border-radius: 999px;
      background: #d1d5db;
      margin: 4px auto 12px;
    }

    .panel-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }

    .panel-title {
      font-size: 1.24rem;
      font-weight: 700;
      line-height: 1.3;
    }

    .panel-meta {
      margin-top: 4px;
      font-size: 0.98rem;
      color: var(--muted);
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .ean-highlight {
      background: #e0f2fe;
      border-radius: 6px;
      padding: 0 4px;
    }

    .status {
      margin-top: 10px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: var(--radius-pill);
      font-size: 0.94rem;
      background: #ecfdf3;
      color: #166534;
      border: 1px solid #c7f2d8;
    }

    .status.unavailable {
      background: #fef2f2;
      color: #991b1b;
      border-color: #fecaca;
    }

    .close {
      border: none;
      background: #f3f4f6;
      color: #374151;
      border-radius: 10px;
      width: 32px;
      height: 32px;
      font-size: 1rem;
      cursor: pointer;
    }

    @media (min-width: 768px) {
      :root {
        --header-height: 104px;
        --search-height: 56px;
      }

      .header-main {
        padding: 0 24px;
      }

      .content {
        max-width: 920px;
        margin: 0 auto;
        padding: 18px 20px 0;
      }

      .search-wrap {
        max-width: 760px;
        margin: 0 auto;
      }

      .categories {
        top: 0;
      }

      .map-section {
        min-height: calc(100dvh - 290px);
      }

      .marker {
        width: 28px;
        height: 28px;
      }

      .product-panel {
        left: 50%;
        right: auto;
        width: calc(100% - 40px);
        max-width: 820px;
        transform: translate(-50%, 100%);
      }

      .product-panel.open {
        transform: translate(-50%, 0);
      }
    }

    @media (min-width: 1100px) {
      :root {
        --header-height: 108px;
      }

      .content {
        max-width: 1240px;
        padding: 20px 32px 0;
      }

      .search-wrap {
        max-width: 840px;
      }

      .map-section {
        min-height: calc(100dvh - 260px);
      }

      .search-side-panel {
        width: min(38vw, 560px);
      }

    }

    @media (min-width: 1500px) {
      .search-side-panel {
        right: 0;
        width: calc((100vw - 1240px) / 2 + 32px);
        max-width: 560px;
      }
    }
  </style>
</head>
<body>
  <main class="app">
    <header class="header">
      <div class="header-main">
        <div class="logo">
          <span class="logo-text">Hitta i Butiken</span>
          <p class="logo-subtitle">Sök efter produkter för att hitta dem på kartan</p>
        </div>
      </div>
    </header>

    <section class="content" aria-label="Store browser">
      <div class="search-wrap">
        <label class="search" aria-label="Search products">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M11 18a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z" stroke="#6B7280" stroke-width="2"/>
            <path d="m20 20-3.5-3.5" stroke="#6B7280" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input id="searchInput" type="text" placeholder="Sök efter produktnamn, EAN-nummer eller kategori..." autocomplete="off" />
        </label>
      </div>

      <nav class="categories" aria-label="Product categories">
        <div class="category-scroll" id="categoryScroll">
          <button class="category active">ALLT</button>
        </div>
      </nav>

      <section class="map-section" aria-label="Store map">
        <div class="map-frame">
          <div class="svg-container" id="svgContainer" aria-label="Interactive store map"></div>
          <div class="map-controls">
            <button class="map-reset-btn" id="resetMapView" type="button">Visa hela kartan</button>
          </div>
          <div class="map-fallback hidden" id="mapFallback">
            <p class="map-help">Kunde inte ladda SVG-kartan. Kontrollera att filen finns i projektmappen.</p>
          </div>
        </div>
      </section>
    </section>
  </main>

  <aside class="search-side-panel" id="searchSidePanel" aria-label="Sökresultat">
    <div class="search-side-head">
      <h3 class="search-side-title">Sökresultat</h3>
      <button class="close" id="closeSearchPanel" aria-label="Stäng sökresultat">X</button>
    </div>
    <p class="search-side-meta" id="searchResultCount">0 träffar</p>
    <ul class="search-side-list" id="searchSideList"></ul>
    <button class="load-more" id="loadMoreBtn" type="button" hidden>Load more</button>
  </aside>

  <aside class="product-panel" id="productPanel" aria-label="Product information panel">
    <div class="drag-handle" aria-hidden="true"></div>
    <div class="panel-top">
      <div>
        <h2 class="panel-title" id="panelName">Organic Avocados</h2>
        <p class="panel-meta">
          <span id="panelCategory">Category: Produce</span>
          <span id="panelEan">EAN: 0000000000000</span>
        </p>
        <p class="panel-meta">
          <span id="panelShelfId">Hyll-ID: -</span>
          <span id="panelSection">Sektion: -</span>
        </p>
        <p class="panel-meta">
          <span id="panelPlanogram">Planogram: -</span>
        </p>
        <span class="status" id="panelStatus">tillgÃ¤nglig</span>
        <div style="margin-top: 10px; display: flex; gap: 10px; flex-wrap: wrap;">
          <button class="map-reset-btn" id="bindShelfToSelected" type="button" title="Klicka pÃ¥ en hylla/zon pÃ¥ kartan och bind den till Hyll-ID">Bind vald yta</button>
          <button class="map-reset-btn" id="clearShelfBinding" type="button" title="Ta bort sparad koppling fÃ¶r denna Hyll-ID">Rensa koppling</button>
        </div>
        <p class="map-help" id="bindingHint" style="margin-top: 8px; max-width: none;">Tips: Klicka pÃ¥ rÃ¤tt hylla/zon i SVG-kartan fÃ¶rst, sedan "Bind vald yta".</p>
      </div>
      <button class="close" id="closePanel" aria-label="Close panel">X</button>
    </div>
  </aside>

  <script>
    const panel = document.getElementById("productPanel");
    const appEl = document.querySelector(".app");
    const closePanel = document.getElementById("closePanel");
    const categoryScroll = document.getElementById("categoryScroll");
    const searchInput = document.getElementById("searchInput");
    const searchSidePanel = document.getElementById("searchSidePanel");
    const closeSearchPanel = document.getElementById("closeSearchPanel");
    const searchResultCount = document.getElementById("searchResultCount");
    const searchSideList = document.getElementById("searchSideList");
    const loadMoreBtn = document.getElementById("loadMoreBtn");
    const panelName = document.getElementById("panelName");
    const panelCategory = document.getElementById("panelCategory");
    const panelEan = document.getElementById("panelEan");
    const panelStatus = document.getElementById("panelStatus");
    const panelShelfId = document.getElementById("panelShelfId");
    const panelSection = document.getElementById("panelSection");
    const panelPlanogram = document.getElementById("panelPlanogram");
    const bindShelfToSelected = document.getElementById("bindShelfToSelected");
    const clearShelfBinding = document.getElementById("clearShelfBinding");
    const bindingHint = document.getElementById("bindingHint");
    const mapFrame = document.querySelector(".map-frame");
    const svgContainer = document.getElementById("svgContainer");
    const resetMapView = document.getElementById("resetMapView");
    const mapFallback = document.getElementById("mapFallback");
    // Put your exported floorplan SVG in the project root and keep this path in sync.
    const STORE_SVG_PATH = "./%C3%84lmhult%20-%20250902.svg";
    const DEFAULT_SHELVES_PATH = "./Hyll%C3%B6vers%C3%A4ttnnig-json.json";
    const DEFAULT_PRODUCTS_PATH = "./planogram_sammanst%C3%A4llning-json.json";
    // Lower value = more zoom-in on first load.
    const INITIAL_MAP_SCALE = 0.60;
    // Negative value nudges the initial map view left.
    const INITIAL_MAP_OFFSET_X = -0.08;
    const ALL_CATEGORY = "ALLT";

    let products = [];
    let shelves = [];
    let activeShelfMatch = null;
    let activeCategory = ALL_CATEGORY;
    let activeQuery = "";
    let activeSearchResults = [];
    let renderedCount = 0;
    const RESULTS_PAGE_SIZE = 30;
    let activeZone = "";
    let svgElement = null;
    let svgOriginalViewBox = null;
    // The "full map" viewBox shown on first load. This is the maximum zoom-out the user is allowed to reach.
    let svgMinZoomViewBox = null;
    let activeShelfElement = null;
    let viewBoxAnimationId = 0;
    let suppressNextShelfClick = false;
    const dragState = {
      active: false,
      moved: false,
      pointerId: null,
      startClientX: 0,
      startClientY: 0,
      startViewBox: null
    };

    const ZONE_POSITIONS = {
      Z1: [19, 3], Z2: [2, 26], Z3: [2, 75], Z4: [19, 97],
      Y1: [51, 4],
      X1: [98, 24], X2: [92, 5], X3: [74, 4],
      C1: [61, 20], C2: [57, 20], C3: [53, 20], C4: [49, 20], C5: [45, 20], C6: [41, 20],
      B1: [76, 48], B2: [76, 42], B3: [76, 36], B4: [76, 30], B5: [76, 24], B6: [76, 19], B7: [76, 14], B8: [76, 9],
      A1: [72, 96], A2: [72, 90], A3: [72, 84], A4: [72, 78], A5: [72, 72], A6: [72, 66], A7: [72, 60], A8: [72, 54],
      A9: [87, 55], A10: [87, 60], A11: [87, 66], A12: [87, 71], A13: [87, 77], A14: [87, 83], A15: [87, 89], A16: [87, 95],
      W1: [86, 100], W2: [99, 74], W3: [64, 61], W4: [69, 100],
      D1: [18, 8], D2: [18, 11], D3: [13, 14], D4: [13, 17], D5: [18, 22], D6: [18, 25], D7: [18, 29], D8: [18, 32],
      D9: [18, 38], D10: [18, 41], D11: [13, 45], D12: [13, 48], D13: [18, 55], D14: [18, 58], D15: [13, 64], D16: [13, 67],
      D17: [18, 72], D18: [18, 75], D19: [13, 80], D20: [13, 83], D21: [18, 89], D22: [18, 92], D23: [13, 97], D24: [13, 100],
      D25: [44, 38], D26: [44, 41], D27: [50, 46], D28: [50, 49], D29: [44, 55], D30: [44, 58],
      D31: [39, 64], D32: [39, 67], D33: [44, 74], D34: [44, 77], D35: [44, 84]
    };

    function canonicalKey(value) {
      return String(value || "")
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9/]/g, "");
    }

    function fixMojibake(value) {
      const text = String(value || "");
      if (!text.includes("Ã") && !text.includes("Â")) return text;
      try {
        return decodeURIComponent(escape(text));
      } catch (error) {
        return text;
      }
    }
    function pickField(item, targets) {
      const keys = Object.keys(item || {});
      for (const key of keys) {
        const parsed = canonicalKey(key);
        for (const target of targets) {
          if (parsed === target || parsed.includes(target)) {
            return item[key];
          }
        }
      }
      return "";
    }
    function normalizeProduct(item) {
      const name = fixMojibake(String(pickField(item, ["produktnamn", "namn", "name"])) ).trim();
      const category = fixMojibake(String(pickField(item, ["kategori", "category"])) ).trim();
      const ean = String(pickField(item, ["ean/plu", "ean", "plu"])) .trim();
      const section = String(pickField(item, ["sektion", "section", "sektion/disk", "sektiondisk"])) .trim();
      const planogramFile = fixMojibake(String(pickField(item, ["filnamn", "planogram-fil", "planogramfil", "planogram"])) ).trim();
      return {
        name,
        category,
        ean,
        section,
        planogramFile,
        sellable: String(pickField(item, ["saljbar", "sljbar", "sellable"])) .trim()
      };
    }

    function normalizeShelf(item) {
      const shelfId = fixMojibake(String(pickField(item, ["hyll-id", "hyllid", "shelfid", "shelf-id"])) ).trim();
      const category = fixMojibake(String(pickField(item, ["kategori", "category"])) ).trim();
      const section = String(pickField(item, ["sektion/disk", "sektiondisk", "sektion", "section", "disk"])) .trim();
      const planogramFile = fixMojibake(String(pickField(item, ["planogram-fil", "planogramfil", "filnamn", "planogram"])) ).trim();
      const comment = fixMojibake(String(pickField(item, ["kommentar", "comment"])) ).trim();
      return { shelfId, category, section, planogramFile, comment };
    }
    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function normalizeValue(value) {
      return String(value || "")
        .toUpperCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");
    }

    function normalizeMatchKey(value) {
      return fixMojibake(String(value || ""))
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, " ")
        .trim();
    }

    function tokenSimilarity(a, b) {
      const aa = normalizeMatchKey(a).split(/\s+/).filter(Boolean);
      const bb = normalizeMatchKey(b).split(/\s+/).filter(Boolean);
      if (!aa.length || !bb.length) return 0;
      const setA = new Set(aa.map((t) => (t.endsWith("s") ? t.slice(0, -1) : t)));
      const setB = new Set(bb.map((t) => (t.endsWith("s") ? t.slice(0, -1) : t)));
      let intersect = 0;
      for (const t of setA) {
        if (setB.has(t)) intersect += 1;
      }
      const union = new Set([...setA, ...setB]).size || 1;
      return intersect / union;
    }

    function bestShelfMatchForProduct(product) {
      if (!product) return null;
      if (!shelves.length) return null;

      const productPlanogram = normalizeMatchKey(product.planogramFile);
      if (productPlanogram) {
        const byPlanogram = shelves.find((s) => normalizeMatchKey(s.planogramFile) === productPlanogram);
        if (byPlanogram) return { shelf: byPlanogram, reason: "planogram", score: 1 };
      }

      const productSection = String(product.section || "").trim();
      const productCategory = product.category || "";
      const sectionCandidates = productSection
        ? shelves.filter((s) => String(s.section || "").trim() === productSection)
        : [];
      if (sectionCandidates.length) {
        let best = sectionCandidates[0];
        let bestScore = tokenSimilarity(best.category, productCategory);
        for (const candidate of sectionCandidates.slice(1)) {
          const score = tokenSimilarity(candidate.category, productCategory);
          if (score > bestScore) {
            best = candidate;
            bestScore = score;
          }
        }
        return { shelf: best, reason: "section+category", score: Math.max(0.7, bestScore) };
      }

      let best = shelves[0];
      let bestScore = tokenSimilarity(best.category, productCategory);
      for (const candidate of shelves.slice(1)) {
        const score = tokenSimilarity(candidate.category, productCategory);
        if (score > bestScore) {
          best = candidate;
          bestScore = score;
        }
      }
      if (bestScore > 0) return { shelf: best, reason: "category", score: bestScore };
      return null;
    }

    const SHELF_SVG_MAP_KEY = "shelfSvgMap:v1";
    function loadShelfSvgMap() {
      try {
        const raw = localStorage.getItem(SHELF_SVG_MAP_KEY);
        const parsed = raw ? JSON.parse(raw) : {};
        return parsed && typeof parsed === "object" ? parsed : {};
      } catch (error) {
        return {};
      }
    }

    function saveShelfSvgMap(map) {
      try {
        localStorage.setItem(SHELF_SVG_MAP_KEY, JSON.stringify(map || {}));
      } catch (error) {
      }
    }

    function getSvgTargetIdForShelf(shelf) {
      if (!shelf || !shelf.shelfId) return "";
      const map = loadShelfSvgMap();
      return String(map[shelf.shelfId] || "").trim();
    }
    function zoneRange(prefix, start, end) {
      const result = [];
      for (let index = start; index <= end; index += 1) {
        result.push(prefix + index);
      }
      return result;
    }

    function pickRandom(list) {
      if (!list || !list.length) return "";
      return list[Math.floor(Math.random() * list.length)];
    }

    function clearZoneHighlight(resetZoom = true) {
      if (activeShelfElement) {
        activeShelfElement.classList.remove("shelf-selected");
      }
      activeShelfElement = null;
      activeZone = "";
      if (resetZoom && svgOriginalViewBox) {
        const initialViewBox = getInitialViewBox();
        animateToViewBox(initialViewBox || svgOriginalViewBox, 420);
      }
    }

    function getCurrentViewBox() {
      if (!svgElement) return null;
      const baseVal = svgElement.viewBox.baseVal;
      if (baseVal && baseVal.width > 0 && baseVal.height > 0) {
        return { x: baseVal.x, y: baseVal.y, width: baseVal.width, height: baseVal.height };
      }
      if (!svgOriginalViewBox) return null;
      return { ...svgOriginalViewBox };
    }

    function setViewBox(viewBox) {
      if (!svgElement || !viewBox) return;
      svgElement.setAttribute("viewBox", [viewBox.x, viewBox.y, viewBox.width, viewBox.height].join(" "));
    }

    function stopViewBoxAnimation() {
      cancelAnimationFrame(viewBoxAnimationId);
      viewBoxAnimationId = 0;
    }

    function clampViewBox(viewBox, options = {}) {
      if (!svgOriginalViewBox || !viewBox) return viewBox;

      const ignoreMinZoom = Boolean(options.ignoreMinZoom);
      const base = svgOriginalViewBox;
      const aspect = base.width / base.height;
      const maxZoomOut = !ignoreMinZoom && svgMinZoomViewBox ? svgMinZoomViewBox : base;
      const minScale = 0.06;
      const maxWidth = Math.min(base.width, maxZoomOut.width);
      const maxHeight = Math.min(base.height, maxZoomOut.height);
      let width = clamp(viewBox.width, base.width * minScale, maxWidth);
      let height = clamp(viewBox.height, base.height * minScale, maxHeight);

      if (Math.abs(width / height - aspect) > 0.0001) {
        if (width / height > aspect) {
          width = height * aspect;
        } else {
          height = width / aspect;
        }
      }

      const minX = base.x;
      const minY = base.y;
      const maxX = base.x + base.width - width;
      const maxY = base.y + base.height - height;

      return {
        x: clamp(viewBox.x, minX, maxX),
        y: clamp(viewBox.y, minY, maxY),
        width,
        height
      };
    }

    function computeInitialViewBox() {
      if (!svgOriginalViewBox) return null;
      const base = svgOriginalViewBox;
      const width = base.width * INITIAL_MAP_SCALE;
      const height = base.height * INITIAL_MAP_SCALE;
      const centerX = base.x + base.width / 2;
      const centerY = base.y + base.height / 2;
      return clampViewBox({
        x: centerX - width / 2 + base.width * INITIAL_MAP_OFFSET_X,
        y: centerY - height / 2,
        width,
        height
      }, { ignoreMinZoom: true });
    }

    function getInitialViewBox() {
      if (!svgOriginalViewBox) return null;
      if (svgMinZoomViewBox) return { ...svgMinZoomViewBox };
      const initial = computeInitialViewBox();
      if (initial) {
        svgMinZoomViewBox = { ...initial };
      }
      return initial;
    }

    function animateToViewBox(target, duration = 540) {
      if (!svgElement || !target) return;
      const start = getCurrentViewBox();
      if (!start) {
        setViewBox(target);
        return;
      }
      stopViewBoxAnimation();
      const clampedTarget = clampViewBox(target);
      const startTime = performance.now();
      const easeInOut = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

      const step = (now) => {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = easeInOut(progress);
        setViewBox(clampViewBox({
          x: start.x + (clampedTarget.x - start.x) * eased,
          y: start.y + (clampedTarget.y - start.y) * eased,
          width: start.width + (clampedTarget.width - start.width) * eased,
          height: start.height + (clampedTarget.height - start.height) * eased
        }));
        if (progress < 1) {
          viewBoxAnimationId = requestAnimationFrame(step);
        } else {
          setViewBox(clampedTarget);
        }
      };

      viewBoxAnimationId = requestAnimationFrame(step);
    }

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function getFocusedViewBox(target) {
      if (!svgOriginalViewBox || !target) return null;
      const box = target.getBBox();
      if (!box || box.width <= 0 || box.height <= 0) return null;

      const base = svgOriginalViewBox;
      const aspect = base.width / base.height;
      const paddingRatio = 0.35;

      let focusWidth = box.width * (1 + paddingRatio);
      let focusHeight = box.height * (1 + paddingRatio);
      if (focusWidth / focusHeight > aspect) {
        focusHeight = focusWidth / aspect;
      } else {
        focusWidth = focusHeight * aspect;
      }

      focusWidth = Math.min(focusWidth, base.width);
      focusHeight = Math.min(focusHeight, base.height);

      const centerX = box.x + box.width / 2;
      const centerY = box.y + box.height / 2;

      const minX = base.x;
      const minY = base.y;
      const maxX = base.x + base.width - focusWidth;
      const maxY = base.y + base.height - focusHeight;

      return {
        x: clamp(centerX - focusWidth / 2, minX, maxX),
        y: clamp(centerY - focusHeight / 2, minY, maxY),
        width: focusWidth,
        height: focusHeight
      };
    }

    function focusShelf(target) {
      if (!target) return;
      clearZoneHighlight(false);
      activeShelfElement = target;
      activeZone = String(target.id || "");
      activeShelfElement.classList.add("shelf-selected");
      const focused = getFocusedViewBox(target);
      if (focused) {
        animateToViewBox(focused, 560);
      }
    }

    function handleMapWheel(event) {
      if (!svgElement || !svgOriginalViewBox) return;
      event.preventDefault();
      const current = getCurrentViewBox();
      if (!current) return;

      const zoomingOut = event.deltaY > 0;
      if (zoomingOut) {
        const maxZoomOut = svgMinZoomViewBox || svgOriginalViewBox;
        const widthEpsilon = Math.max(maxZoomOut.width * 1e-4, 0.0001);
        const heightEpsilon = Math.max(maxZoomOut.height * 1e-4, 0.0001);
        if (current.width >= maxZoomOut.width - widthEpsilon && current.height >= maxZoomOut.height - heightEpsilon) {
          return;
        }
      }

      stopViewBoxAnimation();
      const rect = svgElement.getBoundingClientRect();
      if (!rect.width || !rect.height) return;

      const pointerX = clamp(event.clientX - rect.left, 0, rect.width);
      const pointerY = clamp(event.clientY - rect.top, 0, rect.height);
      const worldX = current.x + (pointerX / rect.width) * current.width;
      const worldY = current.y + (pointerY / rect.height) * current.height;

      const zoomFactor = event.deltaY < 0 ? 0.9 : 1.1;
      const nextWidth = current.width * zoomFactor;
      const nextHeight = current.height * zoomFactor;
      const nextViewBox = clampViewBox({
        x: worldX - (pointerX / rect.width) * nextWidth,
        y: worldY - (pointerY / rect.height) * nextHeight,
        width: nextWidth,
        height: nextHeight
      });

      // If zoom-out was clamped, don't allow the pointer-anchoring math to "pan" the map.
      if (
        zoomingOut &&
        Math.abs(nextViewBox.width - current.width) <= Math.max(current.width * 1e-6, 0.0001) &&
        Math.abs(nextViewBox.height - current.height) <= Math.max(current.height * 1e-6, 0.0001)
      ) {
        return;
      }

      setViewBox(nextViewBox);
    }

    function handleMapPointerDown(event) {
      if (!svgElement || !svgOriginalViewBox) return;
      if (event.pointerType !== "touch" && event.button !== 0) return;
      const startViewBox = getCurrentViewBox();
      if (!startViewBox) return;

      event.preventDefault();
      stopViewBoxAnimation();
      dragState.active = true;
      dragState.moved = false;
      dragState.pointerId = event.pointerId;
      dragState.startClientX = event.clientX;
      dragState.startClientY = event.clientY;
      dragState.startViewBox = { ...startViewBox };
      svgElement.setPointerCapture(event.pointerId);
    }

    function handleMapPointerMove(event) {
      if (!dragState.active || dragState.pointerId !== event.pointerId || !svgElement) return;
      event.preventDefault();
      const rect = svgElement.getBoundingClientRect();
      if (!rect.width || !rect.height) return;

      const deltaX = event.clientX - dragState.startClientX;
      const deltaY = event.clientY - dragState.startClientY;
      if (Math.abs(deltaX) > 4 || Math.abs(deltaY) > 4) {
        dragState.moved = true;
      }

      const viewUnitsPerPixelX = dragState.startViewBox.width / rect.width;
      const viewUnitsPerPixelY = dragState.startViewBox.height / rect.height;
      const panned = clampViewBox({
        x: dragState.startViewBox.x - deltaX * viewUnitsPerPixelX,
        y: dragState.startViewBox.y - deltaY * viewUnitsPerPixelY,
        width: dragState.startViewBox.width,
        height: dragState.startViewBox.height
      });
      setViewBox(panned);
    }

    function handleMapPointerEnd(event) {
      if (!dragState.active || dragState.pointerId !== event.pointerId || !svgElement) return;
      try {
        svgElement.releasePointerCapture(event.pointerId);
      } catch (captureError) {
      }

      const wasDragged = dragState.moved;
      dragState.active = false;
      dragState.moved = false;
      dragState.pointerId = null;
      dragState.startViewBox = null;

      if (wasDragged) {
        suppressNextShelfClick = true;
        setTimeout(() => {
          suppressNextShelfClick = false;
        }, 0);
      }
    }

    function escapeCssId(id) {
      if (window.CSS && typeof window.CSS.escape === "function") {
        return window.CSS.escape(id);
      }
      return String(id).replace(/([ !"#$%&'()*+,./:;<=>?@[\\\]^`{|}~])/g, "\\$1");
    }

    function highlightZone(zone) {
      if (!zone || !svgElement) {
        clearZoneHighlight(false);
        return;
      }
      const target = svgElement.querySelector("#" + escapeCssId(zone));
      if (!target) return;
      focusShelf(target);
    }

    function isIgnoredSvgNode(node) {
      const tag = String(node.tagName || "").toLowerCase();
      return ["svg", "defs", "clipPath", "mask", "pattern", "linearGradient", "radialGradient", "style", "metadata", "desc", "title"].includes(tag);
    }

    function findShelfNode(startNode) {
      let node = startNode;
      while (node && node !== svgElement) {
        if (node.id && !isIgnoredSvgNode(node)) return node;
        node = node.parentElement;
      }
      return null;
    }

    async function initStoreSvg() {
      try {
        const response = await fetch(STORE_SVG_PATH, { cache: "no-cache" });
        if (!response.ok) throw new Error("Failed to load SVG");
        const svgText = await response.text();
        svgContainer.innerHTML = svgText;
        svgElement = svgContainer.querySelector("svg");
        if (!svgElement) throw new Error("No <svg> root in file");

        svgElement.removeAttribute("width");
        svgElement.removeAttribute("height");
        svgElement.setAttribute("preserveAspectRatio", "xMidYMid meet");

        const vb = svgElement.viewBox.baseVal;
        if (vb && vb.width > 0 && vb.height > 0) {
          svgOriginalViewBox = { x: vb.x, y: vb.y, width: vb.width, height: vb.height };
        } else {
          const width = Number(svgElement.getAttribute("width")) || 1000;
          const height = Number(svgElement.getAttribute("height")) || 700;
          svgOriginalViewBox = { x: 0, y: 0, width, height };
          setViewBox(svgOriginalViewBox);
        }

        if (mapFrame && svgOriginalViewBox.width > 0 && svgOriginalViewBox.height > 0) {
          mapFrame.style.aspectRatio = svgOriginalViewBox.width + " / " + svgOriginalViewBox.height;
        }
        const initialViewBox = getInitialViewBox();
        if (initialViewBox) {
          setViewBox(initialViewBox);
        }

        svgElement.addEventListener("click", (event) => {
          if (suppressNextShelfClick) return;
          // Any clicked node (or parent group) with an id is treated as a focusable shelf/area.
          const target = findShelfNode(event.target);
          if (!target) return;
          focusShelf(target);
        });
        svgElement.addEventListener("wheel", handleMapWheel, { passive: false });
        svgElement.addEventListener("pointerdown", handleMapPointerDown);
        svgElement.addEventListener("pointermove", handleMapPointerMove);
        svgElement.addEventListener("pointerup", handleMapPointerEnd);
        svgElement.addEventListener("pointercancel", handleMapPointerEnd);

        mapFallback.classList.add("hidden");
      } catch (error) {
        svgContainer.innerHTML = "";
        mapFallback.classList.remove("hidden");
      }
    }

    function getZoneCandidates(product) {
      const name = normalizeValue(product.name);
      const category = normalizeValue(product.category);

      // Map products/categories to SVG element IDs in the floorplan.
      if (name.includes("KAFFE")) return ["D25"];
      if (category.includes("KROPPSVARD")) return ["D17"];
      if (category.includes("GROV KEM")) return ["D18"];
      if (category.includes("OST")) return ["B6"];
      if (category.includes("FISK") || category.includes("KOTT")) return ["X1"];
      if (category.includes("DRYCKER")) return zoneRange("D", 26, 29);
      if (category.includes("DJUR")) return ["Z3", "Z4"];
      if (category.includes("BARN")) return ["D14", "D15"];
      if (category.includes("BROD")) return [...zoneRange("A", 1, 8), "W3", "W4"];
      if (category.includes("FRUKT") && category.includes("GRONT")) return [...zoneRange("A", 9, 16), "W1", "W2"];
      if (category.includes("MEJERI")) return ["X2", ...zoneRange("B", 5, 8)];
      if (category.includes("DJUPFRYST") || (category.includes("KYLT") && category.includes("VEGETARISKT"))) return zoneRange("C", 1, 6);
      if (category.includes("FARDIGMAT")) return ["Y1"];
      if (category.includes("KONFEKTYR") || category.includes("SNACKS")) return zoneRange("D", 31, 35);
      if (category.includes("SPECIAL") || category.includes("SPECERIER")) return [...zoneRange("D", 1, 24), ...zoneRange("Z", 1, 4)];
      if (category.includes("CHARK")) return zoneRange("B", 1, 4);
      return [];
    }
    function highlightZoneForProduct(product) {
      const match = bestShelfMatchForProduct(product);
      activeShelfMatch = match;
      const shelf = match ? match.shelf : null;
      const explicit = shelf ? getSvgTargetIdForShelf(shelf) : "";
      if (explicit) {
        highlightZone(explicit);
        return;
      }
      const candidates = getZoneCandidates(product);
      highlightZone(candidates[0] || "");
    }
    function isAvailable(product) {
      return ["ja", "yes", "true", "1"].includes(String(product.sellable).toLowerCase());
    }

    function formatEanWithHighlight(eanValue) {
      const ean = String(eanValue || "").trim();
      if (!ean) return "N/A";
      if (ean.length <= 4) {
        return "<span class=\"ean-highlight\">" + escapeHtml(ean) + "</span>";
      }
      const prefix = escapeHtml(ean.slice(0, -4));
      const suffix = escapeHtml(ean.slice(-4));
      return prefix + "<span class=\"ean-highlight\">" + suffix + "</span>";
    }
    function openProductPanel(product) {
      panelName.textContent = product.name || "Unknown product";
      panelCategory.textContent = "Category: " + (product.category || "Unknown");
      panelEan.innerHTML = "EAN: " + formatEanWithHighlight(product.ean);

      const match = bestShelfMatchForProduct(product);
      activeShelfMatch = match;
      if (match && match.shelf) {
        panelShelfId.textContent = "Hyll-ID: " + (match.shelf.shelfId || "-");
        panelSection.textContent = "Sektion: " + (match.shelf.section || "-");
        panelPlanogram.textContent = "Planogram: " + (match.shelf.planogramFile || product.planogramFile || "-");
        panelStatus.textContent = "matchad (" + match.reason + ")";
        panelStatus.classList.remove("unavailable");
      } else {
        panelShelfId.textContent = "Hyll-ID: -";
        panelSection.textContent = "Sektion: -";
        panelPlanogram.textContent = "Planogram: " + (product.planogramFile || "-");
        panelStatus.textContent = "ingen hylla hittad";
        panelStatus.classList.add("unavailable");
      }

      panel.classList.add("open");
      highlightZoneForProduct(product);
    }
    function renderCategories(items) {
      const set = new Set();
      items.forEach((item) => {
        if (item.category) set.add(item.category);
      });
      const categories = [ALL_CATEGORY, ...Array.from(set).sort((a, b) => a.localeCompare(b))];
      categoryScroll.innerHTML = categories
        .map((category) => "<button class=\"category" + (category === activeCategory ? " active" : "") + "\" data-category=\"" + escapeHtml(category) + "\">" + escapeHtml(category) + "</button>")
        .join("");
    }

    function productMatchesQuery(product, query) {
      if (!query) return false;
      const q = query.toLowerCase();
      return (
        product.name.toLowerCase().includes(q) ||
        product.category.toLowerCase().includes(q) ||
        product.ean.toLowerCase().includes(q)
      );
    }

    function getFilteredProducts(query, category) {
      return products
        .filter((product) => category === ALL_CATEGORY || product.category === category)
        .filter((product) => !query || productMatchesQuery(product, query));
    }

    function setSearchPanelOpen(open) {
      searchSidePanel.classList.toggle("open", open);
      appEl.classList.toggle("has-side-panel", open);
    }

    function renderSearchResultBatch(reset) {
      if (reset) {
        renderedCount = 0;
        searchSideList.innerHTML = "";
      }

      const nextCount = Math.min(renderedCount + RESULTS_PAGE_SIZE, activeSearchResults.length);
      const batch = activeSearchResults.slice(renderedCount, nextCount);

      if (batch.length) {
        const startIndex = renderedCount;
        searchSideList.insertAdjacentHTML(
          "beforeend",
          batch
            .map((product, index) => (
              "<li><button class=\"search-result\" type=\"button\" data-result-index=\"" + (startIndex + index) + "\">" +
                "<div class=\"search-result-name\">" + escapeHtml(product.name) + "</div>" +
                "<div class=\"search-result-meta\"><span class=\"search-result-category\">" + escapeHtml(product.category) + "</span> - EAN: " + escapeHtml(product.ean) + "</div>" +
              "</button></li>"
            ))
            .join("")
        );
      }

      renderedCount = nextCount;
      loadMoreBtn.hidden = renderedCount >= activeSearchResults.length;
    }

    function showSideResults(results, summaryText) {
      activeSearchResults = results;
      searchResultCount.textContent = summaryText;
      searchSideList.scrollTop = 0;

      if (!activeSearchResults.length) {
        renderedCount = 0;
        searchSideList.innerHTML = "<li><button class=\"search-result\" type=\"button\"><div class=\"search-result-name\">Inga produkter hittades</div><div class=\"search-result-meta\">Testa namn, kategori eller EAN</div></button></li>";
        loadMoreBtn.hidden = true;
      } else {
        renderSearchResultBatch(true);
      }

      setSearchPanelOpen(true);
    }

    function showCategoryResults(category) {
      const results = getFilteredProducts("", category);
      const summary = category === ALL_CATEGORY
        ? results.length + " produkter i alla kategorier"
        : results.length + " produkter i " + category;
      showSideResults(results, summary);
    }

    function runSearch(query) {
      activeQuery = String(query || "").trim();

      if (!activeQuery) {
        showCategoryResults(activeCategory);
        clearZoneHighlight();
        return;
      }

      const results = getFilteredProducts(activeQuery, activeCategory);
      const summary = results.length + " träffar för \"" + activeQuery + "\"";
      showSideResults(results, summary);
      clearZoneHighlight();
    }
    async function loadProducts() {
      try {
        const response = await fetch(DEFAULT_PRODUCTS_PATH);
        if (!response.ok) throw new Error("Failed to load planogram data");
        const raw = await response.json();
        products = Array.isArray(raw) ? raw.map(normalizeProduct).filter((p) => p.name) : [];
        renderCategories(products);
      } catch (error) {
        try {
          const response = await fetch("./products.json");
          if (!response.ok) throw new Error("Failed to load products.json");
          const raw = await response.json();
          products = Array.isArray(raw) ? raw.map(normalizeProduct).filter((p) => p.name) : [];
          renderCategories(products);
        } catch (fallbackError) {
          products = [];
          renderCategories(products);
        }
      }
    }

    async function loadShelves() {
      try {
        const response = await fetch(DEFAULT_SHELVES_PATH);
        if (!response.ok) throw new Error("Failed to load shelf layout");
        const raw = await response.json();
        shelves = Array.isArray(raw) ? raw.map(normalizeShelf).filter((s) => s.shelfId) : [];
      } catch (error) {
        shelves = [];
      }
    }

    window.findProductLocation = function findProductLocation(query) {
      const q = String(query || "").trim();
      if (!q) return [];
      const digitsOnly = q.replace(/[^\d]/g, "");
      const matches = products.filter((p) => {
        if (digitsOnly.length >= 6) {
          return String(p.ean || "").replace(/[^\d]/g, "") === digitsOnly;
        }
        const hay = normalizeMatchKey([p.name, p.category, p.ean].join(" "));
        return hay.includes(normalizeMatchKey(q));
      });
      return matches.slice(0, 20).map((product) => {
        const match = bestShelfMatchForProduct(product);
        return {
          product,
          shelfId: (match && match.shelf && match.shelf.shelfId) || "",
          category: (match && match.shelf && match.shelf.category) || product.category || "",
          section: (match && match.shelf && match.shelf.section) || product.section || "",
          planogramFile: (match && match.shelf && match.shelf.planogramFile) || product.planogramFile || "",
          matchReason: (match && match.reason) || "",
          matchScore: (match && match.score) || 0
        };
      });
    };
    categoryScroll.addEventListener("click", (event) => {
      const button = event.target.closest(".category");
      if (!button) return;
      activeCategory = button.dataset.category || ALL_CATEGORY;
      Array.from(categoryScroll.querySelectorAll(".category")).forEach((item) => {
        item.classList.remove("active");
      });
      button.classList.add("active");
      showCategoryResults(activeCategory);
      clearZoneHighlight();
    });

    searchInput.addEventListener("keydown", (event) => {
      if (event.key !== "Enter") return;
      event.preventDefault();
      runSearch(searchInput.value);
    });

    searchSideList.addEventListener("click", (event) => {
      const button = event.target.closest("[data-result-index]");
      if (!button) return;
      const index = Number(button.dataset.resultIndex || "-1");
      const product = activeSearchResults[index];
      if (!product) return;
      openProductPanel(product);
      searchInput.value = product.name;
    });

    loadMoreBtn.addEventListener("click", () => {
      renderSearchResultBatch(false);
    });

    closeSearchPanel.addEventListener("click", () => {
      setSearchPanelOpen(false);
      searchSideList.scrollTop = 0;
    });

    closePanel.addEventListener("click", () => {
      panel.classList.remove("open");
      clearZoneHighlight();
    });


    bindShelfToSelected.addEventListener("click", () => {
      const shelfId = activeShelfMatch && activeShelfMatch.shelf ? String(activeShelfMatch.shelf.shelfId || "").trim() : "";
      const selectedSvgId = String(activeZone || "").trim();
      if (!shelfId) {
        bindingHint.textContent = "Ingen Hyll-ID att binda (sÃ¶k och Ã¶ppna en produkt fÃ¶rst).";
        return;
      }
      if (!selectedSvgId) {
        bindingHint.textContent = "Ingen vald yta i kartan. Klicka pÃ¥ en hylla/zon i SVG-kartan fÃ¶rst.";
        return;
      }
      const map = loadShelfSvgMap();
      map[shelfId] = selectedSvgId;
      saveShelfSvgMap(map);
      bindingHint.textContent = "Sparade koppling: " + shelfId + " -> " + selectedSvgId;
    });

    clearShelfBinding.addEventListener("click", () => {
      const shelfId = activeShelfMatch && activeShelfMatch.shelf ? String(activeShelfMatch.shelf.shelfId || "").trim() : "";
      if (!shelfId) {
        bindingHint.textContent = "Ingen Hyll-ID att rensa (sÃ¶k och Ã¶ppna en produkt fÃ¶rst).";
        return;
      }
      const map = loadShelfSvgMap();
      if (map[shelfId]) {
        delete map[shelfId];
        saveShelfSvgMap(map);
      }
      bindingHint.textContent = "Rensade koppling fÃ¶r: " + shelfId;
    });
    resetMapView.addEventListener("click", () => {
      clearZoneHighlight(true);
    });

    initStoreSvg();
    loadShelves();
    loadProducts();
  </script>
</body>
</html>
